{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm:sheety-localization:generate",
      "detail": "Generate localization files from Google Sheets used sheety-localization from npm",
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "file-code"
      },
      "type": "shell",
      "command": [
        "npm install -g sheety-localization &&",
        "sheety-localization --credentials ./credentials.json", // Path to the Google Sheets credentials file
        "--sheet 1iTmPNGoo41_rk2uLThru1WxbnA-K96_OZmsCdLTcWYw", // Google Sheet ID
        "--type=ts", // Set the output index file type to TypeScript
        "--prefix=app", // Prefix for the generated files (e.g., app_en.ts, app_fr.ts)
        "--output=src/l10n", // Directory where the generated files will be placed. Defaults to src/locales
        "--author='Anton Ustinoff <a.a.ustinoff@gmail.com>'", // Author of the generated files, set each generated file
        "--comment='Generated from Google Sheets'", // Comment to be added to each generated file
        "--context='From Google Sheets'" // Context to be added to each generated files
      ],
      "options": {
        "cwd": "${workspaceFolder}/example",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            // без -l могут не подхватиться login-настройки терминала, например, nvm, который может быть использован для управления версиями Node.js
            "-l",
            // без -i часто не подхватывается .zshrc, где обычно и сидит nvm, а без него может не работать команда sheety-localization, если она была установлена через nvm
            "-i",
            // без -c shell просто не знает, что ему нужно выполнить строку команды в виде команды, а не интерактивной оболочки, и просто открывает интерактивную оболочку, ожидая ввода команды, которая так и не приходит
            "-c"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "bin:sheety-localization:generate",
      "detail": "Generate localization files from Google Sheets used local sheety-localization",
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "file-code"
      },
      "type": "shell",
      "command": "node",
      "args": [
        "../bin/generate.min.js",
        "--credentials",
        "./credentials.json", // Path to the Google Sheets credentials file
        "--sheet",
        "1iTmPNGoo41_rk2uLThru1WxbnA-K96_OZmsCdLTcWYw", // Google Sheets ID
        "--type=ts", // Set the output index file type to TypeScript
        "--prefix=app", // Prefix for the generated files (e.g., app_en.ts, app_fr.ts)
        "--output=src/l10n", // Directory where the generated files will be placed. Defaults to src/locales
        "--author=Anton Ustinoff <a.a.ustinoff@gmail.com>", // Author of the generated files, set each generated file
        "--comment=Generated from Google Sheets", // Comment to be added to each generated file
        "--context=From Google Sheets" // Context to be added to each generated files
      ],
      "options": {
        "cwd": "${workspaceFolder}/example",
        "shell": {
          "executable": "/bin/zsh",
          "args": [
            // без -l могут не подхватиться login-настройки терминала, например, nvm, который может быть использован для управления версиями Node.js
            "-l",
            // без -i часто не подхватывается .zshrc, где обычно и сидит nvm, а без него может не работать команда sheety-localization, если она была установлена через nvm
            "-i",
            // без -c shell просто не знает, что ему нужно выполнить строку команды в виде команды, а не интерактивной оболочки, и просто открывает интерактивную оболочку, ожидая ввода команды, которая так и не приходит
            "-c"
          ]
        }
      },
      "problemMatcher": []
    },
  ]
}
